<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= task.title %> - Details</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-light min-vh-100">

  <%- include ('partials/navbar.ejs') %>

  <div class="container my-5">
    <div class="row">
      <div class="col-12 col-lg-6 mx-auto">
        
        <a href="/dash" class="text-white-50 text-decoration-none small mb-4 d-inline-block active-hover">
          ← Back to Dashboard
        </a>

        <div class="card bg-secondary bg-opacity-10 border-secondary p-5 shadow text-light">
          
          <div class="border-bottom border-secondary pb-3 mb-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="badge bg-primary px-3 py-2 rounded-pill fw-semibold">Task ID: #<%= task.id %></span>
              
              <% if (task.completed) { %>
                <span class="text-success fw-medium small">✓ Task Completed</span>
              <% } else { %>
                <span class="text-danger fw-medium small">📅 Due: <%= task.deadline %></span>
              <% } %>
            </div>
            <h2 class="fw-bold text-white mb-0 mt-1 <%= task.completed ? 'text-decoration-line-through text-white-50' : '' %>">
              <%= task.title %>
            </h2>
          </div>

          <div class="mb-4">
            <h6 class="text-white-50 small text-uppercase fw-bold tracking-wider mb-2">Description</h6>
            <p class="text-light leading-relaxed style-text <%= task.completed ? 'text-decoration-line-through text-white-50' : '' %>">
              <%= task.text %>
            </p>
          </div>

          <div class="d-flex gap-2 justify-content-end border-top border-secondary pt-4 mt-4">
            
            <form action="/task/<%= task.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this task?');">
              <button type="submit" class="btn btn-outline-danger btn-sm px-3 fw-medium">Delete Task</button>
            </form>
            
            <% if (!task.completed) { %>
              <form action="/task/<%= task.id %>/complete" method="POST">
                <button type="submit" class="btn btn-success btn-sm px-4 fw-medium">Mark Complete</button>
              </form>
            <% } else { %>
              <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 fw-medium">
                ✓ Completed
              </span>
            <% } %>

          </div>

        </div> </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>